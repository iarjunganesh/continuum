# Continuum — environment configuration
# Copy to .env and fill in real values. Never commit .env.

# --- CockroachDB ---
# From CockroachDB Cloud console -> your cluster -> Connect -> Connection string.
# The free-tier default database is `defaultdb` — that works fine; or create a
# dedicated one: CREATE DATABASE continuum; and swap the path segment below.
#
# sslmode=require: encrypts the connection without verifying the server
# certificate against a CA. CockroachDB Cloud clusters use a cluster-specific
# CA (not a publicly-trusted one), so verify-full needs that exact cluster's
# CA cert on disk (console -> Connect -> download command) — a file that
# won't exist in a fresh container (HF Spaces, Lambda) unless you fetch and
# ship it yourself. `require` needs no cert file and works everywhere;
# acceptable here because Continuum only ever stores synthetic data (ADR 005)
# and this connection only ever reaches CockroachDB Cloud's own endpoint —
# there's nothing confidential in transit to protect against a MITM. If you
# need certificate-pinned verify-full (e.g. for a non-synthetic deployment),
# download your cluster's CA cert and set sslmode=verify-full&sslrootcert=<path>
# instead.
COCKROACH_DATABASE_URL=postgresql://<user>:<password>@<cluster-host>:26257/defaultdb?sslmode=require
COCKROACH_MCP_ENDPOINT=https://cockroachlabs.cloud/mcp
COCKROACH_MCP_API_KEY=

# ccloud CLI (stretch — ADR 004)
CCLOUD_API_KEY=
CCLOUD_CLUSTER_ID=

# --- AWS ---
# eu-central-1 co-locates the Lambda with the CockroachDB Cloud cluster used
# for this build (see docs/adr/007-eu-central-1-region.md).
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# bedrock-runtime calls target THIS region instead of AWS_REGION. Some
# accounts get a hard 0 on-demand/cross-region Bedrock quota in eu-central-1
# (and us-east-1) that isn't self-service adjustable — check with
# `aws service-quotas list-service-quotas --region <region> --service-code
# bedrock` before assuming a region works. eu-west-1 and us-west-2 have full
# default quota. See docs/adr/008-bedrock-region-split.md.
BEDROCK_REGION=eu-west-1

# Bedrock model IDs — VERIFY THESE in Bedrock console -> Model access for
# your chosen region before relying on them; exact IDs/versions roll out
# over time and availability varies by region.
# Titan v2 outputs 1024 dims; must match infra/schema.sql VECTOR(1024).
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDING_DIMENSIONS=1024
# Claude Sonnet 4.5 via the EU cross-region inference profile — confirm under
# Bedrock -> Cross-region inference that this profile is enabled for your account.
BEDROCK_REASONING_MODEL_ID=eu.anthropic.claude-sonnet-4-5-20250929-v1:0

# Lambda (set during deployment, not needed for local dev)
LAMBDA_FUNCTION_NAME=continuum-orchestrator

# --- Remediation loop ---
MAX_REMEDIATION_STEPS=3
STEP_EXECUTION_SECONDS=5

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO
